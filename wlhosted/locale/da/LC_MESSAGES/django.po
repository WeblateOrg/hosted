#: wlhosted/integrations/templates/hosted/create.html:133
msgid ""
"Pricing is based on the number of source strings and target languages. The "
"source string is a text unit defined in a translation format, it can be a "
"word, sentence or paragraph."
msgstr ""
"Priserne er baseret på antallet af kildestrenge og målsprog. Kildestrengen "
"er en tekstenhed defineret i et oversættelsesformat; det kan være et ord, en "
"sætning eller et paragraf."

#: wlhosted/integrations/templates/hosted/create.html:136
msgid "All listed prices exclude VAT."
msgstr "Alle viste priser er ekskl. moms."

#: wlhosted/integrations/templates/hosted/create.html:137
#, python-format
msgid ""
"EU end users and Czech companies will be charged with additional 21%% VAT."
msgstr ""
"Slutbrugere i EU og tjekkiske virksomheder bliver opkrævet yderligere 21%% "
"moms."

#: wlhosted/integrations/templates/hosted/create.html:138
msgid ""
"The reverse charge applies to invoices issued to businesses within the EU."
msgstr ""
"Den omvendte betalingspligt gælder for fakturaer udstedt til virksomheder "
"inden for EU."

#: wlhosted/integrations/templates/mail/billing_paid.html:6
msgid "Thank you for the payment, your billing is now paid."
msgstr "Tak for betalingen; din faktura er nu betalt."

#: wlhosted/integrations/templates/mail/billing_paid.html:8
msgid "This billing plan covers following projects:"
msgstr "Betalingsplanen dækker følgende projekter:"

#: wlhosted/integrations/templates/mail/billing_paid.html:19
msgid "Check your billing status"
msgstr "Tjek din faktureringsstatus"

#: wlhosted/integrations/templates/mail/billing_paid_subject.txt:2
msgid "Your billing plan was paid"
msgstr "Din betalingsplan blev betalt"

#: wlhosted/integrations/views.py:263
msgid "No matching payment found."
msgstr "Ingen matchende betaling fundet."

#: wlhosted/integrations/views.py:271
msgid "Thank you for purchasing a hosting plan, it is now active."
msgstr "Tak for købet af en hostingplan; den er nu aktiv."

#: wlhosted/integrations/views.py:279
msgid ""
"Thank you for purchasing a hosting plan, the payment for it is pending and "
"will be processed in the background."
msgstr ""
"Tak for købet af en hostingplan; betalingen er afventende og bliver "
"behandlet i baggrunden."

#: wlhosted/integrations/views.py:291
msgid "The payment was rejected: {}"
msgstr "Betalingen blev afvist: {}"

#: wlhosted/integrations/views.py:292
msgid "Unknown reason"
msgstr "Ukendt årsag"

#: wlhosted/integrations/views.py:308
msgid "Payments are temporarily inactive."
msgstr "Betalinger er midlertidigt inaktive."

